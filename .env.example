# Summary model
MENTAT_SUMMARY_MODEL=openai/gpt-4o-mini
# MENTAT_SUMMARY_API_KEY=
# MENTAT_SUMMARY_API_BASE=

# Embedding model
MENTAT_EMBEDDING_PROVIDER=openai
MENTAT_EMBEDDING_MODEL=text-embedding-3-small
# MENTAT_EMBEDDING_API_KEY=
# MENTAT_EMBEDDING_API_BASE=

# Storage paths
MENTAT_DB_PATH=./mentat_db
MENTAT_STORAGE_DIR=./mentat_files

# Background processing
MENTAT_MAX_CONCURRENT_TASKS=5

# Section heat tracking
# MENTAT_SECTION_HEAT_HALF_LIFE=86400
# MENTAT_SECTION_HEAT_THRESHOLD=5.0
# MENTAT_SECTION_HEAT_MAX_ENTRIES=1000

# Independent heat-based ranking bias
# MENTAT_SEARCH_HEAT_WEIGHT=0.15

# Reranker
# Enable second-stage reranking after retrieval.
# MENTAT_RERANKER_ENABLED=true
# MENTAT_RERANKER_PROVIDER=cross_encoder
# MENTAT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# MENTAT_RERANKER_TOP_N=10
# MENTAT_RERANKER_CANDIDATE_MULTIPLIER=1
# MENTAT_RERANKER_WEIGHT=0.85

# External reranker example
# MENTAT_RERANKER_PROVIDER=external
# MENTAT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# MENTAT_RERANKER_API_BASE=https://bge-reranker.use2.phala.com/v1/rerank
# MENTAT_RERANKER_API_KEY=your-api-key

# Provider global keys
# OPENAI_API_KEY=
